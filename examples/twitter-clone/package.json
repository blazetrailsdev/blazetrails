{
  "name": "@blazetrails/example-twitter-clone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A tiny Twitter clone built on Express + @blazetrails/activerecord",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "seed": "tsx src/seed.ts",
    "smoke": "tsx src/smoke.ts",
    "dump-schema": "tsx src/dump-schema.ts",
    "typecheck": "trails-tsc --schema db/schema-columns.json --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@blazetrails/activerecord": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
